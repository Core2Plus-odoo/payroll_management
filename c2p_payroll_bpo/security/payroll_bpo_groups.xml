<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="group_ey_payroll_manager" model="res.groups">
        <field name="name">EY: Payroll Manager (all clients)</field>
        <field name="category_id" ref="base.module_category_human_resources_payroll"/>
        <field name="implied_ids" eval="[(4, ref('hr_payroll.group_hr_payroll_manager')),
                                          (4, ref('c2p_payroll_rates.group_payroll_rate_manager'))]"/>
    </record>

    <record id="group_ey_payroll_officer" model="res.groups">
        <field name="name">EY: Payroll Officer (assigned clients)</field>
        <field name="category_id" ref="base.module_category_human_resources_payroll"/>
        <field name="implied_ids" eval="[(4, ref('hr_payroll.group_hr_payroll_user'))]"/>
    </record>

    <record id="group_client_hr" model="res.groups">
        <field name="name">Client HR (own company)</field>
        <field name="category_id" ref="base.module_category_human_resources_payroll"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Manager sees everything the officer and client HR do. -->
    <record id="group_ey_payroll_manager" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_ey_payroll_officer'))]"/>
    </record>

</odoo>
