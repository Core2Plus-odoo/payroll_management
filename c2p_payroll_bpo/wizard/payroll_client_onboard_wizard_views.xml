<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_client_onboard_form" model="ir.ui.view">
        <field name="name">payroll.client.onboard.form</field>
        <field name="model">payroll.client.onboard</field>
        <field name="arch" type="xml">
            <form string="Onboard Client">
                <group>
                    <group>
                        <field name="client_name"/>
                        <field name="client_code"/>
                        <field name="country_id"/>
                        <field name="currency_id"/>
                    </group>
                    <group>
                        <field name="parent_company_id"/>
                        <field name="template_config_id"/>
                        <field name="lock_structure"/>
                        <field name="create_first_cycle"/>
                        <field name="period" invisible="not create_first_cycle"/>
                    </group>
                </group>
                <footer>
                    <button name="action_onboard" type="object" string="Onboard Client" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="action_client_onboard" model="ir.actions.act_window">
        <field name="name">Onboard Client</field>
        <field name="res_model">payroll.client.onboard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
