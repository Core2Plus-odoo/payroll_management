<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Multi-company isolation: a batch / committed input belongs to its client company. -->
    <record id="rule_import_batch_company" model="ir.rule">
        <field name="name">Import batch: own companies</field>
        <field name="model_id" ref="model_payroll_import_batch"/>
        <field name="domain_force">[('client_id','in',company_ids)]</field>
    </record>
    <record id="rule_monthly_input_company" model="ir.rule">
        <field name="name">Monthly input: own companies</field>
        <field name="model_id" ref="model_payroll_monthly_input"/>
        <field name="domain_force">[('client_id','in',company_ids)]</field>
    </record>
</odoo>
