<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_pk" model="ir.ui.view">
        <field name="name">hr.employee.form.pk</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='marital']" position="after">
                <field name="pk_pf_member"/>
                <field name="pk_cnic"/>
                <field name="payroll_province"/>
            </xpath>
        </field>
    </record>
</odoo>
